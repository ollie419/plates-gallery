---
   import { sanityClient } from './lib/sanity';

   const photos = await sanityClient.fetch(`
     *[_type == "photo"] | order(order asc) {
       "src": image.asset->url,
       "width": image.asset->metadata.dimensions.width,
       "height": image.asset->metadata.dimensions.height,
       order
     }
   `);
   ---

   <html>
     <head>
       <title>Plates Gallery</title>
     </head>
     <body>
  <!-- PASSWORD GATE -->
  <div class="gate" id="gate">
    <div class="gate-box">
      <input
        type="password"
        id="pwInput"
        placeholder="enter password"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
      >
      <div class="gate-error" id="gateError">incorrect password</div>
    </div>
  </div>

  <div class="gallery" id="gallery">
    <div class="stage">
      {photos.map((photo, index) => (
        <div class={`slide${index === 0 ? ' active' : ''}`}>
          <img src={photo.src} width={photo.width} height={photo.height} alt="" />
        </div>
      ))}
    </div>
  </div>

  <!-- BOTTOM NAV — info icon only -->
  <nav class="bottom-nav">
    <button id="infoBtn" aria-label="Info">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
      </svg>
    </button>
  </nav>

  <!-- INFO POPUP — Mac-style window -->
  <div class="info-overlay" id="infoOverlay">
    <div class="mac-window">
      <div class="mac-titlebar">
        <button class="mac-btn red"    id="closeBtn" aria-label="Close"></button>
        <button class="mac-btn yellow" aria-label="Minimise" onclick="return false"></button>
        <button class="mac-btn green"  aria-label="Expand"   onclick="return false"></button>
      </div>

      <div class="mac-content">
        <h1>P L A T E 5.</h1>
        <p>
          Good plates. 
        </p>
        <div class="socials">
          <a href="https://instagram.com" target="_blank" aria-label="Instagram">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#f0f0ec" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
     </body>
   </html>

   <style>
   * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: #0a0a0a;
    height: 100dvh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  /* ── GALLERY ── */
  .gallery {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 24px 72px;
    overflow: hidden;
    cursor: pointer;
  }

  .stage {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slide {
    position: absolute;
    display: none;
    align-items: center;
    justify-content: center;
    max-width: min(560px, calc(100vw - 48px));
    max-height: calc(100dvh - 96px);
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .slide.active {
    display: flex;
    pointer-events: auto;
  }

  .slide img {
    max-width: 100%;
    max-height: calc(100dvh - 96px);
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .placeholder {
    width: 500px;
    height: 400px;
    max-width: calc(100vw - 48px);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', 'Courier New', monospace;
    font-size: 48px;
    color: #ccc;
  }

  /* ── BOTTOM NAV ── */
  .bottom-nav {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 28px;
    padding: 0 0 26px;
    z-index: 10;
  }

  .bottom-nav a,
  .bottom-nav button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.35;
    transition: opacity 0.2s;
    color: #fff;
    text-decoration: none;
  }

  .bottom-nav a:hover,
  .bottom-nav button:hover { opacity: 1; }

  .bottom-nav svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* ── INFO OVERLAY (backdrop) ── */
  .info-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .info-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── MAC WINDOW ── */
  .mac-window {
    width: min(480px, calc(100vw - 40px));
    background: #1e1e1e;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.7);
  }

  .mac-titlebar {
    background: #2c2c2c;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid #111;
  }

  .mac-btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    position: relative;
  }

  .mac-btn.red   { background: #ff5f57; }
  .mac-btn.yellow { background: #febc2e; }
  .mac-btn.green  { background: #28c840; }

  .mac-btn.red:hover::after {
    content: '×';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 700;
    color: rgba(0,0,0,0.5);
    line-height: 12px;
  }

  .mac-content {
    padding: 28px 32px 36px;
  }

  .mac-content h1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 28px;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 16px;
    color: #f0f0ec;
  }

  .mac-content p {
    font-family: 'DM Mono', 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.85;
    color: #666;
  }

  .socials {
    display: flex;
    gap: 20px;
    margin-top: 28px;
  }

  .socials a {
    display: inline-flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .socials a:hover { opacity: 1; }

  /* ── PASSWORD GATE ── */
  .gate {
    position: fixed;
    inset: 0;
    background: #0a0a0a;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
  }

  .gate.hidden { display: none; }

  .gate-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: min(300px, calc(100vw - 48px));
  }

  .gate-box input {
    width: 100%;
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 6px;
    padding: 12px 16px;
    font-family: 'DM Mono', 'Courier New', monospace;
    font-size: 14px;
    color: #f0f0ec;
    text-align: center;
    letter-spacing: 0.1em;
    outline: none;
    transition: border-color 0.2s;
  }

  .gate-box input:focus { border-color: #555; }

  .gate-box input.error { border-color: #ff5f57; }

  .gate-error {
    font-family: 'DM Mono', 'Courier New', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: #ff5f57;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .gate-error.show { opacity: 1; }
   </style>

   <script>
  /* ── PASSWORD GATE ── */
  const PASSWORD = '101';

  const gate     = document.getElementById('gate');
  const pwInput  = document.getElementById('pwInput');
  const gateError = document.getElementById('gateError');

  // Stay unlocked for the session
  if (sessionStorage.getItem('unlocked') === 'yes') {
    gate.classList.add('hidden');
  }

  pwInput.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    if (pwInput.value === PASSWORD) {
      sessionStorage.setItem('unlocked', 'yes');
      gate.classList.add('hidden');
      pwInput.value = '';
    } else {
      pwInput.classList.add('error');
      gateError.classList.add('show');
      pwInput.value = '';
      setTimeout(() => {
        pwInput.classList.remove('error');
        gateError.classList.remove('show');
      }, 1800);
    }
  });

  /* ── GALLERY ── */
  const slides     = Array.from(document.querySelectorAll('.slide'));
  const gallery    = document.getElementById('gallery');
  const infoBtn    = document.getElementById('infoBtn');
  const infoOverlay = document.getElementById('infoOverlay');
  const closeBtn   = document.getElementById('closeBtn');

  let current = 0;
  const total = slides.length;

  function goTo(next) {
    if (next === current) return;
    slides[current].classList.remove('active');
    current = next;
    slides[current].classList.add('active');
  }

  function next() { goTo((current + 1) % total); }
  function prev() { goTo((current - 1 + total) % total); }

  /* ── click gallery ── */
  gallery.addEventListener('click', () => {
    if (!infoOverlay.classList.contains('open')) next();
  });

  /* ── swipe ── */
  let tx = 0, ty = 0, moved = false;

  gallery.addEventListener('touchstart', (e) => {
    tx = e.touches[0].clientX;
    ty = e.touches[0].clientY;
    moved = false;
  }, { passive: true });

  gallery.addEventListener('touchmove', () => { moved = true; }, { passive: true });

  gallery.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - tx;
    const dy = e.changedTouches[0].clientY - ty;
    if (!moved || Math.abs(dy) > Math.abs(dx)) return;
    if (dx < -40) next();
    else if (dx > 40) prev();
  });

  /* ── keyboard ── */
  document.addEventListener('keydown', (e) => {
    if (infoOverlay.classList.contains('open') && e.key === 'Escape') {
      infoOverlay.classList.remove('open'); return;
    }
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next();
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   prev();
  });

  /* ── info popup ── */
  infoBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    infoOverlay.classList.add('open');
  });

  closeBtn.addEventListener('click', () => {
    infoOverlay.classList.remove('open');
  });

  /* click backdrop to dismiss */
  infoOverlay.addEventListener('click', (e) => {
    if (e.target === infoOverlay) infoOverlay.classList.remove('open');
  });
   </script>